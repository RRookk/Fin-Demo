# Fin Demo — Environment Variables
# Copy to .env and fill in optional keys for enhanced demo experience

# --- Fin-train ---
# Finnhub API key for fetching real-time financial news
# Get one free at: https://finnhub.io/
FINNHUB_API_KEY=

# --- Finogrid ---
# Demo secret key for API authentication (change in production!)
DEMO_SECRET_KEY=demo-secret-change-me

# Database URL (SQLite is the default, no config needed)
DATABASE_URL=sqlite+aiosqlite:///./fin_demo.db

# Server ports
FIN_TRAIN_PORT=8001
FINOGRID_PORT=8002
